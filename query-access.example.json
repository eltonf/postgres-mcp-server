{
  "requireExplicitColumns": true,
  "databases": {
    "app_db": {
      "schemas": {
        "public": {
          "tables": {
            "mode": "whitelist",
            "list": ["customers", "orders", "products", "order_items"],
            "columnAccess": {
              "customers": {
                "mode": "exclusion",
                "columns": ["password_hash", "api_token"]
              },
              "orders": {
                "mode": "inclusion",
                "columns": ["id", "customer_id", "status", "total", "created_at"]
              }
            }
          }
        }
      }
    }
  }
}
